# SiberCron Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server ──────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database ────────────────────────────────────────────
# SQLite (default, for development)
DATABASE_URL=sqlite://./data/sibercron.db
# PostgreSQL (recommended for production)
# DATABASE_URL=postgres://user:password@localhost:5432/sibercron

# ── Redis (required for BullMQ queue) ───────────────────
REDIS_URL=redis://localhost:6379

# ── Security ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── AI Providers (add the ones you use) ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# ── OAuth (optional) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Messaging Integrations (optional) ───────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
WHATSAPP_ACCESS_TOKEN=

# ── Frontend ────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
