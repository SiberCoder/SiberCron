{
  "name": "@sibercron/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "node --watch-path=./src --import tsx/esm src/main.ts",
    "start": "node dist/main.js",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.0.0",
    "@sibercron/core": "workspace:*",
    "@sibercron/nodes": "workspace:*",
    "@sibercron/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "knex": "^3.1.0",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.0",
    "socket.io": "^4.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/qrcode": "^1.5.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0"
  }
}
